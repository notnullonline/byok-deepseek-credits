{
  "name": "byok-deepseek-credits",
  "displayName": "BYOK DeepSeek Credits",
  "description": "View your DeepSeek API balance and usage. Not affiliated with or endorsed by DeepSeek.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": ["deepseek", "ai", "budget", "byok", "balance", "status bar"],
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/notnullonline/byok-deepseek-credits"
  },
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "byokDeepSeekCredits.refresh",
        "title": "Refresh Balances",
        "category": "BYOK DeepSeek Credits"
      },
      {
        "command": "byokDeepSeekCredits.setApiKey",
        "title": "Set API Key",
        "category": "BYOK DeepSeek Credits"
      }
    ],
    "configuration": {
      "title": "BYOK DeepSeek Credits",
      "properties": {
        "byokDeepSeekCredits.providers.deepseek.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show DeepSeek remaining balance in the status bar."
        },
        "byokDeepSeekCredits.refreshIntervalMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "How often (in minutes) to auto-refresh provider balances."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
